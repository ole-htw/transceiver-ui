# Mission workflow runtime configuration
TRANSCEIVER_ROBOT_HOST=ole@192.168.10.10
# Prefer this explicit command for robust remote ROS environment setup:
TRANSCEIVER_REMOTE_ROS_ENV_CMD=source /opt/ros/jazzy/setup.bash && source ~/ws/install/setup.bash
# Keep this empty when using TRANSCEIVER_REMOTE_ROS_ENV_CMD.
TRANSCEIVER_REMOTE_ROS_SETUP=
# Optional Fast-DDS XML profile path on the remote host (exported as FASTDDS_DEFAULT_PROFILES_FILE and FASTRTPS_DEFAULT_PROFILES_FILE).
TRANSCEIVER_FASTDDS_PROFILES_FILE=
TRANSCEIVER_ROS2_NAMESPACE=
TRANSCEIVER_ROS2_ACTION_NAME=/navigate_to_pose
TRANSCEIVER_NAV_GOAL_ACCEPT_TIMEOUT_S=8.0
TRANSCEIVER_NAV_GOAL_REACHED_TIMEOUT_S=120.0
TRANSCEIVER_NAV_RETRY_ATTEMPTS=0
